start: begin_patch hunk+ end_patch
begin_patch: "*** Begin Patch" LF
end_patch: "*** End Patch" LF?

hunk: update_hunk
update_hunk: "¶" filename ("#" file_hash)? LF line_op*

filename: /([^\s#]+)/
file_hash: /[0-9a-f]{4}/

line_op: insert_before | insert_after | replace | delete
