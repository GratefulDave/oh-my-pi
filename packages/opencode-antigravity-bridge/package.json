{
	"type": "module",
	"name": "@oh-my-pi/opencode-antigravity-bridge",
	"version": "15.5.7",
	"description": "OMP provider bridge for the OpenCode Antigravity auth plugin",
	"homepage": "https://omp.sh",
	"author": "Derek Rynd",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/can1357/oh-my-pi.git",
		"directory": "packages/opencode-antigravity-bridge"
	},
	"bugs": {
		"url": "https://github.com/can1357/oh-my-pi/issues"
	},
	"keywords": [
		"opencode",
		"antigravity",
		"oauth",
		"extension"
	],
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"test": "bun test test",
		"lint": "biome lint .",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"@oh-my-pi/pi-ai": "workspace:*",
		"@oh-my-pi/pi-utils": "workspace:*",
		"opencode-antigravity-auth": "1.6.5-beta.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14"
	},
	"peerDependencies": {
		"@oh-my-pi/pi-coding-agent": "15.5.7"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"omp": {
		"extensions": [
			"./src/extension.ts"
		]
	},
	"files": [
		"src",
		"README.md"
	]
}
